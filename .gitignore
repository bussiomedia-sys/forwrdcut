# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.ruff_cache/

# Models (download separately — see docs/ENGINE.md). Large binaries, not for git.
# Leading slash = repo root only, so these never match same-named CODE packages
# nested under src/ (e.g. src/forwrdcut/media/ is the ffmpeg/ffprobe wrappers).
/models/

# Working data — never commit footage, renders, caches, or analysis output
/media/
/cache/
/renders/
/outputs/

# Licensed music: yours to use, NOT yours to redistribute — never commit it
assets/music/licensed/
*.mp4
*.mov
*.MOV
*.MP4
*.wav
!assets/music/*.wav
!assets/sfx/*.wav

# Secrets / local config
.env
.env.*
*.local.toml
secrets.*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
